# LLM backend — leave unset to use Ollama (gemma3:12b)
# Set ANTHROPIC_API_KEY to switch to Claude automatically
# ANTHROPIC_API_KEY=sk-ant-...

# Override Ollama model (default: gemma3:12b)
# OLLAMA_MODEL=gemma3:12b

# Override Ollama server URL (default: http://localhost:11434/v1)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Override Claude model (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Override GPT-SoVITS TTS server URL (default: http://localhost:9880)
# TTS_API_URL=http://localhost:9880
