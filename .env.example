# Persona: narrator (Darkest Dungeon), warhammer (WH40K), default (plain)
# PERSONA=warhammer

# Whisper model size (default: large-v3-turbo)
# Smaller = faster on CPU: medium, small, base
# WHISPER_MODEL=large-v3-turbo

# LLM backend — priority: Gemini > Claude > Ollama
# Set GOOGLE_API_KEY for Gemini (free tier available at aistudio.google.com)
# GOOGLE_API_KEY=AIzaSyCv2xyRCtNMYvrpFy--FKosaQDXBxn39bk

# Set ANTHROPIC_API_KEY for Claude (paid)
# ANTHROPIC_API_KEY=sk-ant-...

# Override Gemini model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Override Ollama model (default: qwen2.5-1.5b-abliterated)
# OLLAMA_MODEL=qwen2.5-1.5b-abliterated

# Override Ollama server URL (default: http://localhost:11434/v1)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Ollama GPU layers: 0=CPU/RAM only, -1=auto (full GPU), N=offload N layers to GPU
# Default is 0 (CPU) to leave VRAM free for GPT-SoVITS TTS
# OLLAMA_NUM_GPU=0

# Override Claude model (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# TTS backend: "gptsovits" (default, needs server) or "omnivoice" (local, no server)
# TTS_BACKEND=omnivoice

# Override GPT-SoVITS TTS server URL (default: http://localhost:9880)
# TTS_API_URL=http://localhost:9880

# OmniVoice settings (only used when TTS_BACKEND=omnivoice)
# OMNIVOICE_MODEL=k2-fsa/OmniVoice
# OMNIVOICE_DEVICE=cuda:0   # or "cpu"

# Audio output device name or index (run "python -c 'import sounddevice; print(sounddevice.query_devices())'" to list)
# AUDIO_OUTPUT_DEVICE=pipewire
# AUDIO_OUTPUT_DEVICE=pulse

# TTS delivery tuning
# TTS_SPEED=1.0        # 0.5 (slow/grave) → 2.0 (fast) — try 0.85 for deeper gravitas
# TTS_TEMPERATURE=1.0  # higher = more expressive/varied, lower = more stable/flat
# TTS_TOP_P=1.0        # nucleus sampling — lower = safer/less creative
# TTS_TOP_K=15         # top-k sampling — higher = more variety
